# ==========================================
# BRASETZ - ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Copy this to .env.local for local development
# Add these to your Vercel Environment Variables
# All variables are REQUIRED for production deployment

# ==========================================
# GOOGLE APPS SCRIPT CONFIGURATION
# ==========================================
# Google Apps Script Web App URL (REQUIRED)
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbz3yvN7WfSq4FUD6zUA9ss9TzwUhBHF4iGEeuiuR1kh39GaZ5Tf9twWps45D38qUUyX1Q/exec

# Google Apps Script ID (REQUIRED)
VITE_GOOGLE_APPS_SCRIPT_ID=AKfycbz3yvN7WfSq4FUD6zUA9ss9TzwUhBHF4iGEeuiuR1kh39GaZ5Tf9twWps45D38qUUyX1Q

# Google Sheet ID (OPTIONAL - for specific sheet targeting)
VITE_GOOGLE_SHEET_ID=your_google_sheet_id_here

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Admin email for notifications (REQUIRED)
VITE_ADMIN_EMAIL=admin@brasetz.com

# Application environment (REQUIRED)
VITE_APP_ENV=production

# Site URL (REQUIRED for analytics and redirects)
VITE_SITE_URL=https://your-domain.vercel.app

# ==========================================
# ANALYTICS CONFIGURATION
# ==========================================
# Google Analytics Measurement ID (REQUIRED)
VITE_GA_MEASUREMENT_ID=G-P6CP2GW9QH

# Vercel Analytics (Automatically enabled - no config needed)

# ==========================================
# DEVELOPMENT CONFIGURATION
# ==========================================
# API base URL (for development)
VITE_API_BASE_URL=https://script.google.com/macros/s

# Debug mode (set to 'false' in production)
VITE_DEBUG=false

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# CORS allowed origins (comma-separated)
VITE_CORS_ORIGINS=https://your-domain.vercel.app,https://localhost:8080

# Rate limiting (requests per minute)
VITE_RATE_LIMIT=10
